<% content_for :title, "Showing user" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Showing user</h1>

  <%= render @user %>

  <div class="flex flex-wrap gap-2">
    <%= link_to "Edit this user", edit_user_path, class: "btn btn-ghost" %>
    <%= button_to "Destroy this user", user_path, method: :delete, class: "btn btn-error", data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>
