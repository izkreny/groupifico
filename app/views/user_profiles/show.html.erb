<% content_for :title, "Showing user profile" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Showing user profile</h1>

  <%= render @user_profile %>

  <div class="flex flex-wrap gap-2">
    <%= link_to "Edit this user profile", edit_user_profile_path, class: "btn btn-ghost" %>
    <%= button_to "Destroy this user profile", user_profile_path, method: :delete, class: "btn btn-error", data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>
