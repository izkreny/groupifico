<% content_for :title, "Showing address" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Showing address</h1>

  <%= render @address %>

  <div class="flex flex-wrap gap-2">
    <%= link_to "Edit this address", edit_address_path(@address), class: "btn btn-ghost" %>
    <%= link_to "Back to addresses", addresses_path, class: "btn btn-ghost" %>
    <%= button_to "Destroy this address", address_path(@address), method: :delete, class: "btn btn-error", data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>
