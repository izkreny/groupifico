<div id="<%= dom_id group %>" class="w-full sm:w-auto my-5 space-y-5">
  <ul>
    <li>
      <strong><%= group.name.upcase %></strong>
      (<%= group.group_type %>)
      <br>
      <%= group.address&.name %>
      <br>
      <%= link_to "Members", group_members_path(group) %>
      |
      <%= link_to "Events", group_events_path(group) %>
    </li>
  </ul>
  <p><%= group.description %></p>
</div>
