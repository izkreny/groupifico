<% content_for :title, "Groups" %>

<div class="w-full">
  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Groups</h1>
    <%= link_to "New group", new_group_path, class: "btn btn-primary" %>
  </div>

  <div id="groups" class="min-w-full divide-y divide-base-300 space-y-5">
    <% if @groups.any? %>
      <% @groups.each do |group| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
          <%= render group %>
          <div class="w-full sm:w-auto flex flex-col sm:flex-row space-x-2 space-y-2">
            <%= link_to "Show", group_path(group), class: "btn btn-ghost" %>
            <%= link_to "Edit", edit_group_path(group), class: "btn btn-ghost" %>
            <%= button_to "Destroy", group_path(group), method: :delete, class: "btn btn-error", data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10">No groups found.</p>
    <% end %>
  </div>
</div>
