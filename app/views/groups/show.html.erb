<% content_for :title, "Showing group" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Showing group</h1>

  <%= render @group %>

  <div class="flex flex-wrap gap-2">
    <%= link_to "Edit this group", edit_group_path(@group), class: "btn btn-ghost" %>
    <%= link_to "Back to groups", groups_path, class: "btn btn-ghost" %>
    <%= button_to "Destroy this group", group_path(@group), method: :delete, class: "btn btn-error", data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>
