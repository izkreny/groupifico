<%= form_with(model: group, class: "contents") do |form| %>
  <% if group.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(group.errors.count, "error") %> prohibited this group from being saved:</h2>

      <ul class="list-disc ml-6">
        <% group.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="inline">
    <%= form.label      :name %>
    <%= form.text_field :name %>

    <%= form.label     :description %>
    <%= form.text_area :description %>

    <%= form.fields_for :address do |address_form| %>
      <%= address_form.label :name, class: "label" do %>
        <%= tag.span :name.to_s.capitalize, class: "label" %>
        <%= address_form.text_field :name %>
      <% end %>

      <%= address_form.label :street_name %>
      <%= address_form.text_field :street_name %>

      <%= address_form.label :building_number %>
      <%= address_form.text_field :building_number %>

      <%= address_form.label :city %>
      <%= address_form.text_field :city %>

      <%= address_form.label :postal_code %>
      <%= address_form.text_field :postal_code %>

      <%= address_form.label :state_code %>
      <%= address_form.text_field :state_code %>

      <%= address_form.label :country_code %>
      <%= address_form.text_field :country_code %>

      <%= address_form.label :latitude %>
      <%= address_form.text_field :latitude %>
      <%= address_form.label :longitude %>
      <%= address_form.text_field :longitude %>
    <% end %>

    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
