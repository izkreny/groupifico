<% content_for :title, "Editing group" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Editing group</h1>

  <%= render "form", group: @group %>

  <div class="flex flex-wrap gap-2">
    <%= link_to "Show this group", group_path(@group), class: "btn btn-ghost" %>
    <%= link_to "Back to groups", groups_path, class: "btn btn-ghost" %>
  </div>
</div>
