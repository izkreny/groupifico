<%= form_with(model: [group, event], class: "contents") do |form| %>
  <%= render "shared/errors", object: event %>

  <div class="main">
    <%= form.label      :name %>
    <%= form.text_field :name %>

    <%= form.label     :description %>
    <%= form.text_area :description %>

    <%= form.label          :starts_at %>
    <%= form.datetime_field :starts_at %>

    <%= form.label          :ends_at %>
    <%= form.datetime_field :ends_at %>

    <%= form.label  :status %>
    <%= form.select :status, event_statuses %>

    <%= form.label  :category %>
    <%= form.select :category, event_categories %>

    <%= form.label             :creator_id %>
    <%= form.collection_select :creator_id, event.group.members, :id, :full_name %>

    <%= form.label             :manager_id %>
    <%= form.collection_select :manager_id, event.group.members, :id, :full_name %>

    <% if event.group.addresses.present? %>
      <br>
      <strong>
        <%= event.address.persisted? ? "Change address:" : "Select existing address:" %>
      </strong>
      <br>
      <%= form.label             :address_id %>
      <%= form.collection_select :address_id, event.group.addresses, :id, :name, prompt: true %>
    <% end %>
    <br>

    <% if event.address.persisted? %>
      <%= link_to "Edit '#{event.address.name}' address", edit_address_path(event.address), target: "_blank" %>
      |
      <%= link_to "Create new address", new_address_path, target: "_blank" %>
    <% else %>
      <strong>
        Create new address:
      </strong>
      <br>
      <%= form.fields_for :address do |address_form| %>
        <%= render "addresses/form_fields", form: address_form %>
      <% end %>
    <% end %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
