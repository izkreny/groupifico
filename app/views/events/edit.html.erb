<% content_for :title, "Editing event" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Editing event</h1>

  <%= render "form", group: @group, event: @event %>

  <div class="flex flex-wrap gap-2">
    <%= link_to "Show this event", group_event_path(@group, @event), class: "btn btn-ghost" %>
    <%= link_to "Back to events", group_events_path(@group), class: "btn btn-ghost" %>
  </div>
</div>
