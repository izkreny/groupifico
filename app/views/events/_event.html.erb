<div id="<%= dom_id event %>" class="w-full sm:w-auto my-5 space-y-5">
  <strong>
    <%= event.name %>
  </strong>
  (<%= event.category %>)
  <br>
  <%= event_schedule(event) %> (<%= event.status %>)
  <br>
  @ <%= event.address&.name %>
  <br>
  Created by <%= event.creator&.full_name %>
  |
  Managed by <%= event.manager&.full_name %>
  <br>
  <%= link_to "Registrations", group_event_registrations_path(event.group, event) %>
</div>
