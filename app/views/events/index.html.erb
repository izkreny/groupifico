<% content_for :title, "Events" %>

<div class="w-full">
  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl"><%= link_to @group.name, group_path(@group) %> Events</h1>
    <%= link_to "New event", new_group_event_path(@group), class: "btn btn-primary" %>
  </div>

  <div id="events" class="min-w-full divide-y divide-base-300 space-y-5">
    <% if @events.any? %>
      <% @events.each do |event| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
          <%= render event %>
          <div class="w-full sm:w-auto flex flex-col sm:flex-row space-x-2 space-y-2">
            <%= link_to "Show", group_event_path(@group, event), class: "btn btn-ghost" %>
            <%= link_to "Edit", edit_group_event_path(@group, event), class: "btn btn-ghost" %>
            <%= link_to "Duplicate", duplicate_group_event_path(@group, event), class: "btn btn-ghost" %>
            <%= button_to "Destroy", group_event_path(@group, event), method: :delete, class: "btn btn-error", data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10">No events found.</p>
    <% end %>
  </div>
</div>
