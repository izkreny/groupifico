<% content_for :title, "Showing event" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Showing event</h1>

  <%= render @event %>

  <div class="flex flex-wrap gap-2">
    <%= link_to "Edit this event", edit_group_event_path(@group, @event), class: "btn btn-ghost" %>
    <%= link_to "Duplicate this event", duplicate_group_event_path(@group, @event), class: "btn btn-ghost" %>
    <%= link_to "Back to events", group_events_path(@group), class: "btn btn-ghost" %>
    <%= button_to "Destroy this event", group_event_path(@group, @event), method: :delete, class: "btn btn-error", data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>
