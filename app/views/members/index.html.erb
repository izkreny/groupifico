<% content_for :title, "Members" %>

<div class="w-full">
  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl"><%= link_to @group.name, group_path(@group) %> Members</h1>
    <%= link_to "New member", new_group_member_path(@group), class: "btn btn-primary" %>
  </div>

  <div id="members" class="min-w-full divide-y divide-base-300 space-y-5">
    <% if @members.any? %>
      <% @members.each do |member| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
          <%= render member %>
          <div class="w-full sm:w-auto flex flex-col sm:flex-row space-x-2 space-y-2">
            <%= link_to "Show", group_member_path(@group, member), class: "btn btn-ghost" %>
            <%= link_to "Edit", edit_group_member_path(@group, member), class: "btn btn-ghost" %>
            <%= button_to "Destroy", group_member_path(@group, member), method: :delete, class: "btn btn-error", data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10">No members found.</p>
    <% end %>
  </div>
</div>
