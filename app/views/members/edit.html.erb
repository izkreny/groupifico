<% content_for :title, "Editing member" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Editing member</h1>

  <%= render "form", group: @group, member: @member %>

  <div class="flex flex-wrap gap-2">
    <%= link_to "Show this member", group_member_path(@group, @member), class: "btn btn-ghost" %>
    <%= link_to "Back to members", group_members_path(@group), class: "btn btn-ghost" %>
  </div>
</div>
