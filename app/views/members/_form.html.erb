<%= form_with(model: [group, member], class: "contents") do |form| %>
  <%= render "shared/errors", object: member %>

  <div class="main">
    <%= form.label  :status %>
    <%= form.select :status, member_statuses %>

    <%= form.label  :role %>
    <%= form.select :role, member_roles %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
