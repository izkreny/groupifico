<% content_for :title, "Editing registration" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Editing registration</h1>

  <%= render "form", group: @group, event: @event, registration: @registration %>

  <div class="flex flex-wrap gap-2">
    <%= link_to "Show this registration", group_event_registration_path(@group, @event, @registration), class: "btn btn-ghost" %>
    <%= link_to "Back to registrations", group_event_registrations_path(@group, @event), class: "btn btn-ghost" %>
  </div>
</div>
