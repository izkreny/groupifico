<% content_for :title, "Editing registration" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Editing registration</h1>

  <%= render "form", group: @group, event: @event, registration: @registration %>

  <%= link_to "Show this registration", group_event_registration_path(@group, @event, @registration), class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <%= link_to "Back to registrations", group_event_registrations_path(@group, @event), class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
</div>
