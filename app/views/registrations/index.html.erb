<% content_for :title, "Registrations" %>

<div class="w-full">
  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl"><%= link_to @group.name, group_path(@group) %> <%= link_to @event.name, group_event_path(@group, @event) %> Registrations</h1>
    <%= link_to "New registration", new_group_event_registration_path(@group, @event), class: "btn btn-primary" %>
  </div>

  <div id="registrations" class="min-w-full divide-y divide-base-300 space-y-5">
    <% if @registrations.any? %>
      <% @registrations.each do |registration| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
          <%= render registration %>
          <div class="w-full sm:w-auto flex flex-col sm:flex-row space-x-2 space-y-2">
            <%= link_to "Show", group_event_registration_path(@group, @event, registration), class: "btn btn-ghost" %>
            <%= link_to "Edit", edit_group_event_registration_path(@group, @event, registration), class: "btn btn-ghost" %>
            <%= button_to "Destroy", group_event_registration_path(@group, @event, registration), method: :delete, class: "btn btn-error", data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10">No registrations found.</p>
    <% end %>
  </div>
</div>
